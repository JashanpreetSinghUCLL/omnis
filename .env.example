# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...

# Helicone gateway proxy (optional — enables automatic cost tracking + latency metrics)
# Sign up at https://helicone.ai, then set your key here.
# When set, ALL LLM calls are transparently proxied through Helicone.
# Helicone = gateway metrics (cost/RPM/latency P95)
# Langfuse  = deep trace analysis (per-node timing, faithfulness, retrieval scores)
# HELICONE_API_KEY=sk-helicone-...
OPENAI_API_KEY=sk-...
VOYAGE_API_KEY=pa-...

# Ingestion
LLAMA_CLOUD_API_KEY=                     # optional — falls back to PyMuPDF

# Qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=           # uncomment and set for Qdrant Cloud

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=neo4j/omnis_dev_password      # user/password format for docker-compose
NEO4J_USER=neo4j
NEO4J_PASSWORD=omnis_dev_password

# Redis
REDIS_URL=redis://:omnis_dev_redis@localhost:6379/0
REDIS_PASSWORD=omnis_dev_redis

# Langfuse
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=lf-pk-omnis-dev
LANGFUSE_SECRET_KEY=lf-sk-omnis-dev
LANGFUSE_POSTGRES_PASSWORD=langfuse_dev_pass
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse_dev_pass
LANGFUSE_NEXTAUTH_SECRET=super_secret_langfuse_dev
LANGFUSE_SALT=langfuse_salt_dev
LANGFUSE_ADMIN_EMAIL=admin@omnis.local
LANGFUSE_ADMIN_PASSWORD=admin_dev_pass

# Application
APP_ENV=development                      # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change_me_in_production   # generate: python -c "import secrets; print(secrets.token_hex(32))"
LOG_LEVEL=INFO
# Production only: comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=https://app.omnis.io,https://omnis.io

# Taskiq
TASKIQ_BROKER_URL=redis://:omnis_dev_redis@localhost:6379/1

# Frontend container build-time settings
# In Docker: nginx proxies /v1/* to the api container — leave VITE_API_BASE_URL empty.
# For local `pnpm dev` (no nginx): auto-falls back to http://localhost:8000.
# Only set this if you need to point at a remote API (e.g. staging).
# VITE_API_BASE_URL=
# Optional explicit WS endpoint. Leave empty to auto-derive from VITE_API_BASE_URL.
VITE_WS_BASE_URL=

